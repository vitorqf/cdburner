DEBUG=false
DATABASE_URL=sqlite:////storage/cdburner.db

# Storage paths (inside container — match the Docker volume mount)
STORAGE_PATH=/storage
UPLOADS_PATH=/storage/uploads
CONVERTED_PATH=/storage/converted
TEMP_PATH=/storage/temp
COVERS_PATH=/storage/uploads/covers

# CD device passed through from the host
CD_DEVICE=/dev/sr0

# Limits
MAX_UPLOAD_MB=200
YT_DLP_MAX_PLAYLIST=50
